Screen {
  layout: vertical;
}

#banner {
  height: 1;
  padding: 0 1;
  background: $surface-darken-1;
}

#main-layout {
  height: 1fr;
}

#file-tree {
  dock: left;
  width: 28;
}

#markdown-view {
  width: 2fr;
}

#code-view {
  width: 2fr;
}

#info-panel {
  dock: right;
  width: 30;
}

#markdown-view:focus,
#code-view:focus,
#file-tree:focus {
  border: tall $accent;
}
